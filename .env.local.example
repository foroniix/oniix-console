ANALYTICS_INGEST_KEY=REPLACE_ME
# Secret used to sign/verify short-lived mobile ingest tokens.
# Recommended: random 32+ chars.
# Optional: if omitted, server falls back to NEXTAUTH_SECRET, ANALYTICS_INGEST_KEY,
# then SUPABASE_SERVICE_ROLE_KEY/SUPABASE_SERVICE_ROLE.
ANALYTICS_INGEST_TOKEN_SECRET=REPLACE_ME
# JSON map (recommended): {"tenant_uuid":"tenant_ingest_key"}
# or flat format: tenant_uuid:tenant_ingest_key,tenant_uuid_2:key2
ANALYTICS_INGEST_KEYS=REPLACE_ME
